@model IEnumerable<ProductModel>
@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>
@if (Model != null)
{
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-sm-3 mb-3">
                <div class="card">
                    <img style="height:150px" src="@product.ImageUrl" alt="@product.Name" />
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">@product.Description</p>
                        @if (CurrentUser != null)
                        {
                            <button class="btn btn-primary" onclick="addToCart(@product.ProductId, @product.UnitPrice, 1)">
                                Add to Cart
                            </button>
                        }
                        else
                        {
                            <a href="/Account/Login?returnUrl=/" class="btn btn-secondary">Add to Cart</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <h3>No Products found...</h3>
}
